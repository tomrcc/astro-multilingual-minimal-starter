---
import type { Page } from "astro";
import BlogList from "../../../components/blog/list.astro";
import BlogPagination from "../../../components/blog/pagination";
import Layout from "../../../layouts/Paginated.astro";
import { getCollection, getEntry, type CollectionEntry } from "astro:content";
import { localeCodes, blogCollectionFor } from "../../../utils/locales";

type Props = {
  page: Page<CollectionEntry<"blog">>;
  locale: string;
};

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const page = await getEntry("pages", "blog");
  if (!page) return [];
  const pageSize = "page_size" in page.data ? page.data.page_size : 6;

  const paths = [];
  for (const locale of localeCodes) {
    const posts = await getCollection(blogCollectionFor(locale));
    posts.sort((a, b) => {
      const aDate = new Date(a.data.post_hero.date);
      const bDate = new Date(b.data.post_hero.date);
      return bDate.getTime() - aDate.getTime();
    });
    paths.push(...paginate(posts, { params: { locale }, pageSize }));
  }
  return paths;
}

const { locale } = Astro.props;
const page = await getEntry("pages", "blog");
const frontmatter = page?.data;
const pagination = Astro.props.page;
const { data: posts } = pagination;
---

<Layout frontmatter={frontmatter} roseyRoot="blog">
  <div class="mx-auto max-w-6xl px-8 py-16">
    <h1
      class="text-3xl md:text-4xl font-bold text-center mb-8"
      data-rosey="title"
    >
      {frontmatter.title}
    </h1>
    <div class="max-w-md mx-auto mb-8">
      <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
      <script is:inline src="/pagefind/pagefind-ui.js"></script>
      <div id="search"></div>
      <script is:inline>
        window.addEventListener("DOMContentLoaded", () => {
          new PagefindUI({ element: "#search", showSubResults: true });
        });
      </script>
    </div>
    <section>
      <BlogList posts={posts} locale={locale} />
      <BlogPagination pagination={pagination} basePath={`/${locale}/blog`} />
    </section>
  </div>
</Layout>
